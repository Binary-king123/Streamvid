DATABASE_URL="postgresql://streamvid_user:CHANGE_THIS_PASSWORD@localhost:5432/streamvid?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="CHANGE_THIS_TO_64_RANDOM_CHARS_EXAMPLE_abc123xyz456abc123xyz456abc123xyz456abc123xyz456abc123"
VIDEO_STORAGE_PATH="/var/www/videos"
UPLOADS_PATH="/var/www/uploads"
PORT=4000
NODE_ENV=production

# SITE_MODE controls content filtering per deployment:
# mainstream = hides adult content
# adult      = shows only adult content (age gate enabled)
SITE_MODE=adult

# Optional: maximum concurrent FFmpeg encoding jobs (default: 2)
MAX_ENCODING_JOBS=2
