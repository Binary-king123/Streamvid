    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.53.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
